DATABASE_URL=postgresql://localhost:5432/sansvisavis
# Interface admin (Étape 1). Ne jamais préfixer NEXT_PUBLIC_ : secrets serveur uniquement.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Module Internaute — secret DÉDIÉ des jetons-capacité de rectification publique. DISTINCT du secret admin
# (ne jamais réutiliser ADMIN_SESSION_SECRET). Secret aléatoire ≥ 32 octets.
INTERNAUTE_TOKEN_SECRET=
# URL PUBLIQUE ABSOLUE du site (ex. https://www.sansvisavis.com), SERVEUR uniquement (jamais NEXT_PUBLIC_ : elle
# n'est construite que côté serveur, dans le QR/lien de vérification du certificat PDF). Doit inclure le schéma
# http(s). ABSENTE ou mal formée → le PDF N'EST PAS généré : un QR pointant vers une URL fausse serait pire qu'un
# certificat sans document (la carte/le PDF sont re-fabricables une fois la variable posée).
SITE_URL=
# Envoi du certificat par e-mail (SMTP Google Workspace, via nodemailer). SERVEUR uniquement (jamais NEXT_PUBLIC_).
# ⚠️ SMTP_USER ≠ MAIL_FROM : noreply@sansvisavis.com est un ALIAS Workspace (pas une boîte, il ne peut pas
# s'authentifier). On S'AUTHENTIFIE avec le compte réel (SMTP_USER) et on ENVOIE EN TANT QUE l'alias (MAIL_FROM).
# SMTP_PASS est un MOT DE PASSE D'APPLICATION Workspace : ne JAMAIS mettre sa valeur ici, ni en git, ni dans un log.
# Une variable absente/mal formée → PAS d'envoi (log + return) : un envoi à moitié configuré est pire qu'absent.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
